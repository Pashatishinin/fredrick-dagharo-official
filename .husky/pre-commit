#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "\n🚀 [PRE-COMMIT] Running code quality checks..."


echo "🧹 [1/3] Linting and formatting (Biome)..."
npx lint-staged || { echo "\n❌ [ERROR] Linting failed. Please fix the issues before committing."; exit 1; }


echo "🧪 [2/3] Checking types (TypeScript)..."
npm run check-all || { echo "\n❌ [ERROR] Type checking failed. Please check the code in frontend or studio."; exit 1; }


echo "🏗️  [3/3] Running test build..."
npm run build:all || { echo "\n❌ [ERROR] Build failed. Commit aborted."; exit 1; }

echo "\n✨ [SUCCESS] All checks passed! Ready to commit."