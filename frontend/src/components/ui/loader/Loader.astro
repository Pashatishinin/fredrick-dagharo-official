<div id="loader">
  <img src="/loading2.gif" alt="Loading..." />
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #010101;
    z-index: 999999;
  }
</style>

<script>
  import { gsap } from "gsap";

  const initLoader = () => {
    const loader = document.getElementById("loader");
    const main = document.getElementById("main-content");

    if (!loader || !main) return;

    const tl = gsap.timeline();

    tl.to({}, { duration: 3 })
      .to(loader, { scale: 1.5, duration: 0.5 })
      .to(loader, {
        opacity: 0,
        duration: 0.5,
        onComplete: () => {
          loader.style.display = "none";
        },
      })
      .to(main, { opacity: 1, duration: 0.8, ease: "power2.inOut" });
  };

  initLoader();
</script>
