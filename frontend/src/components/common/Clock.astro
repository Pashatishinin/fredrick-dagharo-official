<div class="flex flex-col items-end uppercase">
  <span id="current-time">00:00:00</span>
  <span id="current-location">Loading location...</span>
</div>

<script>
  let timerId: number | undefined;

  function updateTime() {
    const timeElement = document.getElementById("current-time");
    if (timeElement) {
      timeElement.innerText = new Date().toLocaleTimeString("en-GB", {
        hour12: false,
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
      });
    }
  }

  function getLocation() {
    const locElement = document.getElementById("current-location");
    if (!locElement) return;

    try {
      const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
      const offset = -new Date().getTimezoneOffset() / 60;
      const gmtDisplay = `GMT${offset >= 0 ? "+" : ""}${offset}`;
      locElement.innerText = `${timeZone} (${gmtDisplay})`;
    } catch (e) {
      locElement.innerText = "Location unavailable";
    }
  }

  function initClock() {
    if (timerId) {
      clearInterval(timerId);
    }

    updateTime();
    getLocation();

    timerId = window.setInterval(updateTime, 1000);
  }

  document.addEventListener("astro:page-load", initClock);

  document.addEventListener("astro:before-preparation", () => {
    if (timerId) clearInterval(timerId);
  });
</script>
