---
import { Vimeo } from "@astro-community/astro-embed-vimeo";
import Layout from "../../layouts/Layout.astro";
import GallerySection from "../../views/project/GallerySection/GallerySection.astro";
import InfoSection from "../../views/project/InfoSection/InfoSection.astro";
import NextSection from "../../views/project/NextSection/NextSection.astro";
---

<Layout>
  <div class="group relative w-full min-h-screen overflow-hidden">
    <div class="video-wrapper absolute inset-0 z-0 w-full mx-auto">
      <Vimeo
        id="https://vimeo.com/392460230"
        params="controls=1&muted=0&autoplay=1"
      />
    </div>

    <img
      src="/image.jpg"
      alt="Project Cover"
      class="view parallax-element absolute top-0 left-0 w-full h-full object-cover z-10 cursor-pointer transition-opacity duration-300"
    />
  </div>
  <InfoSection />
  <GallerySection />
  <NextSection />
</Layout>

<style is:global>
  .video-wrapper {
    position: absolute;
    top: 50%; /* Центрируем по вертикали */
    left: 50%; /* Центрируем по горизонтали */
    transform: translate(-50%, -50%);

    /* Жесткие 90% высоты */
    height: 90vh !important;
    width: calc(90vh * 1.77777778) !important;

    /* Ограничения для мобилок */
    max-width: 90vw;
    max-height: calc(90vw * 0.5625);

    overflow: hidden;
    z-index: 0;
  }

  /* СБРОС ВНУТРЕННИХ СТИЛЕЙ VIMEO */
  .video-wrapper [data-vimeo-embed],
  .video-wrapper lite-vimeo {
    padding-top: 0 !important; /* Убираем тот самый лишний отступ! */
    height: 100% !important;
    width: 100% !important;
    position: absolute !important;
    top: 0;
    left: 0;
  }

  /* Растягиваем сам iframe на весь враппер */
  .video-wrapper iframe {
    width: 100% !important;
    height: 100% !important;
    border: none;
    /* Если хочешь, чтобы видео заполняло всё пространство без черных полос: */
    object-fit: cover;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/dist/ScrollTrigger";

  import { initParallax } from "../../shared/animation/parallax";
  import Player from "@vimeo/player";

  gsap.registerPlugin(ScrollTrigger);

  function setupParallax() {
    const elements = document.querySelectorAll(
      ".parallax-element:not(.initialised)",
    );

    elements.forEach((el) => {
      if (el instanceof HTMLElement) {
        initParallax(el, 20);
        el.classList.add("initialised");
      }
    });

    ScrollTrigger.refresh();
  }

  function initProjectCard() {
    const containers = document.querySelectorAll(".group");

    containers.forEach((container) => {
      const img = container.querySelector(".view") as HTMLElement;
      if (!img) return;

      // Инициализация параллакса (если нужно)
      if (!img.classList.contains("initialised")) {
        initParallax(img, 20);
        img.classList.add("initialised");
      }

      img.onclick = () => {
        // 1. Мгновенно скрываем картинку
        img.style.display = "none";

        // 2. Находим iframe и запускаем видео
        const iframe = container.querySelector("iframe");
        if (iframe) {
          const player = new Player(iframe);

          // Используем ready(), чтобы убедиться, что API Vimeo готово принимать команды
          player.ready().then(() => {
            player.play().catch((error) => {
              console.error("Видео не смогло запуститься:", error);
              // Если браузер блокирует звук, запускаем без звука (fallback)
              player.setMuted(true);
              player.play();
            });
          });
        }
      };
    });
  }

  // Запуск при обычной загрузке и при использовании Astro View Transitions

  initProjectCard();
  document.addEventListener("astro:page-load", initProjectCard);

  setupParallax();

  document.addEventListener("astro:page-load", setupParallax);

  window.addEventListener("load", () => ScrollTrigger.refresh());
</script>
