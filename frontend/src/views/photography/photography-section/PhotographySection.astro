        <a href="/"
          ><DecodeText duration={1} class="my-custom-style"
            >ALL PROJECTS</DecodeText
          ></a
        >
      </li>
      {
        categories.map((category) => (
          <li>
            <a href={`/categories/${category}`}>
              <DecodeText duration={1} class="my-custom-style">
                {category.title.toUpperCase()}
              </DecodeText>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div
    class="w-full grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-2 gap-2 py-4 grid-flow-dense"
  >
    {
      data.map((item, index) => {
        return (
          <div class={item.isBig ? "sm:col-span-2 sm:row-span-2" : ""}>
            <a href={item.link}>
              <Card
                number={(index + 1).toString().padStart(2, "0")}
                isBig={item.isBig}
                data={item}
              />
            </a>
          </div>
        );
      })
    }
  </div>
